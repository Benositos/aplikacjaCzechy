# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Drift code-gen — regenerated per machine via `dart run build_runner build`
**/*.g.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Per-machine paths and signing config — never commit
android/local.properties
android/key.properties
android/app/upload-keystore.jks
android/app/release.keystore

# iOS — Pods reinstall via `pod install`, generated configs are per-machine
ios/Pods/
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/.symlinks/

# Snapshot of the pre-timezone state — pushed to its own repo. Not part of
# the active project tree, exclude here to avoid double-shipping it.
beta1.0/

# Local-only — design references, screenshots, original developer's notes.
# Not needed for the port.
docs/
zdj/
